# =============================================================================
# 安全敏感文件（绝不能进镜像）
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
secrets/
credentials*

# =============================================================================
# Git / CI
# =============================================================================
.git/
.gitignore
.github/
.gitlab-ci.yml

# =============================================================================
# Python 缓存与虚拟环境（镜像里会重建）
# =============================================================================
.venv/
venv/
env/
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.installed.cfg

# =============================================================================
# 测试与开发工具（生产镜像不需要）
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
tests/
docs/

# =============================================================================
# 数据与日志（容器启动时会重建索引，挂载 volume 才持久化）
# =============================================================================
data/chroma/
*.log
logs/

# =============================================================================
# IDE / OS
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================================
# Docker 自身文件（避免递归）
# =============================================================================
Dockerfile
docker-compose.yml
.dockerignore

# =============================================================================
# 学习笔记（与生产镜像无关）
# =============================================================================
../learning-notes/
