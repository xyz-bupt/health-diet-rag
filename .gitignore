# =============================================================================
# 全局 .gitignore（仓库根 = 健康饮食rag/）
# 同时管理 health-diet-rag/ 和 learning-notes/
# =============================================================================

# =============================================================================
# 🔒 敏感信息（绝不能提交）
# =============================================================================
.env
.env.*
!.env.example
*.key
*.pem
secrets/
credentials*

# =============================================================================
# 🐍 Python 缓存与字节码
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
build/
dist/
.installed.cfg

# =============================================================================
# 📦 虚拟环境（每个开发机自己建）
# =============================================================================
.venv/
venv/
env/
ENV/

# =============================================================================
# 🧪 测试与覆盖率
# =============================================================================
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# =============================================================================
# 💾 运行时产物
# =============================================================================
# ChromaDB 索引（容器启动会重建，体积大）
data/chroma/
# HuggingFace 模型缓存
.cache/
*.bin

# =============================================================================
# 📝 日志
# =============================================================================
*.log
logs/

# =============================================================================
# 💻 IDE / 编辑器
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# 🖥️ 操作系统
# =============================================================================
.DS_Store
Thumbs.db
desktop.ini

# =============================================================================
# 📓 Jupyter
# =============================================================================
.ipynb_checkpoints/

# =============================================================================
# 🐳 Docker（构建产物，不提交）
# =============================================================================
# 不忽略 Dockerfile / docker-compose.yml，但要忽略本地构建产物
